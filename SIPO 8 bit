module sipo_8bit(
    input        clk,
    input        rst,
    input        serial_in,
    output [7:0] par_out
);
    reg [7:0] sr;
    always @(posedge clk or posedge rst) begin
        if (rst) sr <= 8'b0;
        else     sr <= {serial_in, sr[7:1]};
    end
    assign par_out = sr;
endmodule

