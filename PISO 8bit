module piso_8bit(
    input        clk,
    input        rst,
    input        load,        // 1 = load parallel, 0 = shift
    input  [7:0] par_in,
    output       serial_out
);
    reg [7:0] sr;
    always @(posedge clk or posedge rst) begin
        if (rst)       sr <= 8'b0;
        else if (load) sr <= par_in;
        else           sr <= {1'b0, sr[7:1]};   // shift right
    end
    assign serial_out = sr[0];
endmodule
